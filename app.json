{
  "expo": {
    "name": "Treino-Tracker",
    "slug": "Treino-Tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "treinotracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
  },
  "plugins": [
    [
      "expo-splash-screen",
      {
        "backgroundColor": "#208AEF",
        "android": {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      }
    ]
  ],
  "experiments": {
    "reactCompiler": true
  }
}
